# Allow direct access to PHP API files
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /api/

    # If the file exists, serve it directly
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]
</IfModule>

# PHP settings
<IfModule mod_php.c>
    php_flag display_errors Off
    php_flag log_errors On
</IfModule>